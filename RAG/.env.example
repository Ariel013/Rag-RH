# ─── Base de données PostgreSQL (Supabase) ────────────────────────────────
# Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:[MOT_DE_PASSE]@db.xxxx.supabase.co:5432/postgres

# ─── Supabase Storage (pour les documents uploadés) ───────────────────────
# Settings > API > Project URL
SUPABASE_URL=https://xxxx.supabase.co
# Settings > API > Project API keys > service_role (secret)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── HuggingFace Inference API (embeddings — remplace PyTorch local) ──────
# https://huggingface.co/settings/tokens → New token (Read)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Configuration LLM ────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# Pour Groq (gratuit, rapide) :
#   OLLAMA_BASE_URL=https://api.groq.com/openai/v1
#   OLLAMA_MODEL=llama-3.1-8b-instant
#   GROQ_API_KEY=gsk_xxxx

# ─── Admin & Sécurité ─────────────────────────────────────────────────────
# Identifiants du compte administrateur
ADMIN_EMAIL=admin@rag.com
ADMIN_PASSWORD=changez_ce_mot_de_passe

# Token secret — générez-en un avec : python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_TOKEN=votre_token_secret_aleatoire

# Origines autorisées pour les requêtes cross-origin (séparées par virgule, ou * pour tout autoriser)
ALLOWED_ORIGINS=*
