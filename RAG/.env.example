# ─── Base de données PostgreSQL (Supabase) ────────────────────────────────
# Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:[MOT_DE_PASSE]@db.xxxx.supabase.co:5432/postgres

# ─── Configuration LLM (Ollama — gratuit, local, aucune clé requise) ─────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# Modèles recommandés (faire `ollama pull <nom>`) :
#   llama3.2      (~2 GB)  rapide, bon pour le français
#   mistral       (~4 GB)  meilleure qualité en français
#   llama3.1:8b   (~5 GB)  excellent 
